# Environment variables for the application

# PostgreSQL database connection URL
DATABASE_URL="postgres://user:password@host:6767/database_name"
# Node environment (development, production, etc.)
NODE_ENV="development"

# Owner Phone Number (numbers only)
OWNER_PHONE_NUMBER="1234567890"
# Set to true if only the owner can use the bot, false allows anyone to use it
OWNER_ONLY=false
# Default prefix for commands, separated by space
PREFIX="! opc. ."
